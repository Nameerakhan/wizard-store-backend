# ── OpenAI ────────────────────────────────────────────────────────────────────
# Your OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Railway managed PostgreSQL — copy from Railway Variables tab
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Vector Store ──────────────────────────────────────────────────────────────
# "chroma" for local development (default), "qdrant" for production
VECTOR_STORE=chroma

# Qdrant Cloud — only needed when VECTOR_STORE=qdrant
# Cluster URL from https://cloud.qdrant.io (format: https://xxx.qdrant.io:6333)
QDRANT_URL=https://your-cluster.qdrant.io:6333
# API key from Qdrant Cloud → your cluster → API Keys
QDRANT_API_KEY=
# Name of the Qdrant collection (created automatically on first use)
QDRANT_COLLECTION_NAME=wizard_store
